{
	"name": "burst-statistics/burst-mainwp",
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true,
			"phpstan/extension-installer": true
		}
	},
	"require": {
		"php": ">=7.4"
	},
	"require-dev": {
		"wp-coding-standards/wpcs": "^3.0",
		"phpcompatibility/phpcompatibility-wp": "*",
		"yoast/phpunit-polyfills": "^1.1.0",
		"wp-cli/wp-cli-bundle": "^2.8",
		"phpunit/phpunit": "^9.5",
		"phpstan/phpstan": "^2.1",
		"php-stubs/wordpress-stubs": "^6.8",
		"phpstan/extension-installer": "^1.4",
		"squizlabs/php_codesniffer": "^3.12",
		"dealerdirect/phpcodesniffer-composer-installer": "^1.0",
		"yoast/wp-test-utils": "^1.2",
		"wp-phpunit/wp-phpunit": "^6.2",
		"phpstan/phpstan-strict-rules": "^2.0",
		"slevomat/coding-standard": "^8.18",
		"php-stubs/woocommerce-stubs": "^10.2"
	},
	"scripts": {
		"phpstan": "vendor/bin/phpstan analyse --memory-limit=2G",
		"phpstan:gitlab": "vendor/bin/phpstan analyse --memory-limit=2G --configuration=phpstan.gitlab.neon",
		"phpstan:wp-env": "vendor/bin/phpstan analyse --memory-limit=2G --configuration=phpstan.wp-env.neon",
		"lint": "./vendor/bin/phpcs --standard=phpcs.xml.dist",
		"lint:report": "./vendor/bin/phpcs --report=summary",
		"lint:fix": "./vendor/bin/phpcbf --standard=nocomment-fix-php.xml.dist",
		"phpunit": "vendor/bin/phpunit --configuration phpunit.xml.dist"
	}
}
